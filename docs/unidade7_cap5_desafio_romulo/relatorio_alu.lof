\babel@toc {brazil}{}\relax 
\contentsline {figure}{\numberline {1}{\ignorespaces Esquemático do somador \textit {Ripple-Carry} de 8~bits, base das operações ADD e SUB. A cadeia de carry $C_0 \to C_1 \to \cdots \to C_{\text {out}}$ determina o caminho crítico de timing.}}{11}{figure.caption.2}%
\contentsline {figure}{\numberline {2}{\ignorespaces Esquemáticos das 6~operações lógicas e de deslocamento do ALUChip v1.0 (representação de 1~bit). As operações lógicas são de profundidade 1~nível; os deslocamentos requerem apenas reconexão de fios (\textit {zero latency}).}}{12}{figure.caption.3}%
\contentsline {figure}{\numberline {3}{\ignorespaces Diagrama das 4~\textit {flags} de estado do ALUChip v1.0 e suas equações booleanas de geração.}}{12}{figure.caption.4}%
\contentsline {figure}{\numberline {4}{\ignorespaces Diagrama de blocos top-level do ALUChip v1.0: entradas A[7:0], B[7:0] e OP[2:0]; saídas RESULT[7:0] e flags Z, C, V, N.}}{13}{figure.caption.5}%
\contentsline {figure}{\numberline {5}{\ignorespaces Formas de onda da simulação funcional extraídas de \texttt {dump\_alu.vcd}. Cada grupo de operação é identificado por marcadores verticais. Na fase ADD/SUB, observa-se a ativação dos sinais \texttt {flag\_c}, \texttt {flag\_v} e \texttt {flag\_n} nos casos de borda; nas operações lógicas e de deslocamento, as flags C e V permanecem em 0.}}{14}{figure.caption.6}%
\contentsline {figure}{\numberline {6}{\ignorespaces Tabela resumida dos resultados da simulação funcional: 18 vetores representativos dos 27 aplicados, com resultado e flags esperados versus obtidos.}}{15}{figure.caption.7}%
\contentsline {figure}{\numberline {7}{\ignorespaces Esquerda: atraso de propagação pré-\textit {layout} vs.\ pós-\textit {layout} por grupo de operação. Direita: decomposição do caminho crítico (ADD/SUB) em estágios lógicos.}}{15}{figure.caption.8}%
\contentsline {figure}{\numberline {8}{\ignorespaces \textit {Floorplan} estimado do ALUChip v1.0 em die de 120\,\textmu m\,$\times $\,120\,\textmu m. Blocos internos: somador (azul), unidade lógica (verde), deslocador (laranja), MUX 8:1 (roxo) e lógica de flags (vermelho). Pads de I/O circundam o \textit {core}.}}{16}{figure.caption.10}%
